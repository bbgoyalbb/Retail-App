node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
test_reports/
.pytest_cache/
htmlcov/
*.coverage
.coverage

# Production builds
/build
dist/
dist

# Environment files (comprehensive coverage)
*token.json*
*credentials.json*

# Logs and debug files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
*.pem

# Python
__pycache__/
*pyc*
venv/
.venv/

# Backend: secrets, SSL certs, compiled frontend build, user uploads
backend/.env
backend/.jwt_secret
backend/ssl.key
backend/ssl.crt
backend/frontend/
backend/static/uploads/
backend/.jwt_secret.lock

# Git config — should not be tracked in version control
.gitconfig

# Development tools
.ipynb_checkpoints/

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

