# Copy this file to .env before starting the frontend dev server:
#   cp frontend/.env.sample frontend/.env
#
# REACT_APP_BACKEND_URL — base URL of the FastAPI backend (no trailing slash)
#   In production this is the HTTPS address served by build_and_run.bat
#   In development you can use http://localhost:8001
REACT_APP_BACKEND_URL=https://192.168.31.17:8001

# REACT_APP_ENABLE_SEED — set to "true" to enable the DB seed button in DataManager
REACT_APP_ENABLE_SEED=false
