# ============================================================
# Backend environment variables — copy to .env and fill in
# NEVER commit .env to version control.
# ============================================================

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017

# MongoDB database name
DB_NAME=retail_db

# Comma-separated allowed CORS origins.
# Development (local only):  CORS_ORIGINS=http://localhost:3000
# LAN deployment:            CORS_ORIGINS=https://192.168.1.10:8001
# Multiple origins:          CORS_ORIGINS=http://localhost:3000,https://192.168.1.10:8001
# WARNING: Do NOT use * in production — it allows any website to query your API.
CORS_ORIGINS=http://localhost:3000

# JWT secret key — MUST be changed to a unique random value before first use.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# Set to true only in a fully isolated local dev environment.
# true enables Swagger UI (/docs) and exposes the full API schema.
DEBUG=false

# API key for backup/restore endpoints (leave blank to disable the extra auth layer)
ADMIN_API_KEY=

# Path to Excel seed file (used by /seed endpoint)
SEED_FILE_PATH=/tmp/retail_book.xlsm
